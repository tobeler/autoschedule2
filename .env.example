# =============================================================
# Jetson dispatcher — environment variables
# Copy this file to `.env.local` for local dev. In production these
# values are set via the Vercel project's Environment Variables UI.
# =============================================================

# --- HubSpot (Phase 13: server-only token, never NEXT_PUBLIC_*) ---
# Portal 21424670 · na1. Get a private app token at
#   HubSpot → Settings → Integrations → Private Apps.
# Required scopes: crm.objects.contacts.read/write, crm.objects.deals.read,
#   crm.schemas.contacts.read, crm.schemas.deals.read,
#   crm.schemas.custom.read, crm.objects.custom.read,
#   crm.objects.custom.write (for the Jobs custom-object write-back),
#   crm.objects.0-970.read/write (native Projects).
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# HubSpot app client secret. Used to verify HMAC-SHA-256 signatures
# on inbound webhooks at /api/webhooks/hubspot.
HUBSPOT_APP_SECRET=

# Jetson HubSpot portal ID (helpful for log messages and the
# Integrations panel). 21424670 = Jetson's na1 portal.
HUBSPOT_PORTAL_ID=21424670

# --- Vercel Cron auth ---
# Generate with `openssl rand -base64 32`. Vercel injects this as
# `Authorization: Bearer <CRON_SECRET>` when invoking the cron entry.
CRON_SECRET=

# --- Internal service auth ---
# Shared secret for the outbox-drain endpoint, called by the Supabase
# Database Webhook on `outbox` INSERT. Generate with
# `openssl rand -hex 32`.
INTERNAL_SHARED_SECRET=

# --- Sentry (optional, leave blank to disable) ---
# Project DSN from sentry.io. App boots fine when this is empty.
NEXT_PUBLIC_SENTRY_DSN=

# --- Database (Phase 10: Supabase Postgres via Drizzle) ---
# Use the *direct* connection string for migrations (not the pgbouncer
# pooled URL). team-lead will paste the real value into .env.local +
# Vercel after provisioning the Supabase project.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# --- NextAuth (Phase 10) ---
# Generate a 32-byte secret:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-32-byte-base64-secret
# Public URL the app is reached at. Local dev: http://localhost:3010.
# Production: https://autoschedule2.vercel.app (or the custom domain).
NEXTAUTH_URL=http://localhost:3010
